# Supabase Postgres connection string (Session pooler or direct)
DATABASE_URL="postgresql://postgres:password@host:5432/postgres?schema=public"
# Used by Prisma migrate against a non-pooled endpoint when DATABASE_URL is pgbouncer
DIRECT_URL="postgresql://postgres:password@host:5432/postgres?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# App
APP_NAME="Invoice Generator"
DEFAULT_CURRENCY="EUR"

# Local storage paths (relative to project root)
UPLOAD_DIR="./uploads"
